# Application Settings
APP_NAME=GCM Web UI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./gcm_webui.db

# Security
ENCRYPTION_KEY=your-fernet-key-here-generate-with-cryptography
SESSION_EXPIRE_MINUTES=480

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Feature Flags
# Set to true to enable IT Asset and Crypto Object sync tabs and views.
# Default is false (Scanner + Profiles are always available).
ENABLE_ASSET_SYNC=false

# ─── Authentication Notes ────────────────────────────────────────────────────
# Credentials are stored per-profile in the database (encrypted with
# ENCRYPTION_KEY). There is no global auth config in this file.
#
# Each profile has an auth_method field — set it when creating/editing a
# profile in the UI or via the API (POST /api/v1/profiles).
#
# OIDC profile example (auth_method = "oidc"):
#   app_uri      = "https://gcm-host:31443"
#   oidc_uri     = "https://oidc-host:30443"   ← required for OIDC
#   realm        = "gcmrealm"
#   auth_method  = "oidc"
#   client_id    = "gcmclient"
#   client_secret= ""                          ← encrypted at rest
#   username     = "admin"                     ← encrypted at rest
#   password     = "secret"                    ← encrypted at rest
#
# API key profile example (auth_method = "api_key"):
#   app_uri      = "https://gcm-host:31443"
#   oidc_uri     =                             ← not required; leave blank
#   auth_method  = "api_key"
#   api_key      = "Bearer your-api-key-here"  ← encrypted at rest; store the full
#                                                value as GCM issues it, including
#                                                the "Bearer " prefix.
#                                                sent as: Authorization: Bearer <key>
#                                                         token_type: api_key
#
# Note: The Login & Authorize step on the Authentication tab is only needed
#       for OIDC profiles. API key profiles authenticate automatically on
#       every request — no separate login step is required.
# ─────────────────────────────────────────────────────────────────────────────